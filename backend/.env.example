# Resume Shortlister Backend Configuration

# ==========================================
# DATABASE - MySQL Configuration (Migrated from MongoDB)
# ==========================================
# Update these for your MySQL provider (PlanetScale, Render, Railway, or Local)

DB_HOST=localhost
DB_USER=root
DB_PASSWORD=password
DB_PORT=3306
DB_NAME=resume_shortlister

# ==========================================
# JWT & SECURITY
# ==========================================
# IMPORTANT: Change this to a strong random string in production!
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ==========================================
# API KEYS
# ==========================================
ANTHROPIC_API_KEY=your_anthropic_key_here
GOOGLE_AI_API_KEY=your_google_ai_key_here

# ==========================================
# APPLICATION SETTINGS
# ==========================================
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
PORT=5000

# ==========================================
# DATABASE PROVIDER EXAMPLES
# ==========================================

# LOCAL MySQL:
# DB_HOST=localhost
# DB_USER=resume_user
# DB_PASSWORD=password123

# PLANETSCALE:
# DB_HOST=xxxxx-xxxxx.mysql.database.azure.com
# DB_USER=xxxxx
# DB_PASSWORD=pscale_pw_xxxxx

# RENDER:
# DB_HOST=dpg-xxxxx.render.internal
# DB_USER=postgres
# DB_PASSWORD=xxxxx

# RAILWAY:
# Use the connection string from Railway dashboard

